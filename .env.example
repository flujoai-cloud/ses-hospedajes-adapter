# .env.example — PLANTILLA. Copia este fichero a  .env  y rellénalo.
# NO subir .env al repositorio (ya está en .gitignore). NO pegar credenciales en el código.
#
# Cargar antes de ejecutar el script, por ejemplo:
#     set -a; source scripts/.env; set +a
#     python3 scripts/ses_hospedajes.py --enviar

# Entorno: 'pre' (pruebas) o 'pro' (producción). Mantener 'pre' hasta validar.
SES_HOSPEDAJES_ENTORNO=pre

# --- SECRETOS (usuario de servicio web; el usuario termina en 'WS') ---
# Se obtienen una vez en la Sede Electrónica con certificado. Tratar como credenciales de banca.
SES_HOSPEDAJES_USUARIO=
SES_HOSPEDAJES_PASSWORD=

# --- Datos por hotel (no secretos, pero configurables en un único sitio — Fase 4) ---
SES_HOSPEDAJES_CODIGO_ARRENDADOR=
SES_HOSPEDAJES_CODIGO_ESTABLECIMIENTO=
SES_HOSPEDAJES_APLICACION=BORRADOR-SES-Hospedajes
